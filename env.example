# ──────────────────────────────────────────────
# Amazon Vendor Central credentials
# ──────────────────────────────────────────────
EMAIL=your-amazon-email@example.com
AMAZON_PASSWORD=your-amazon-password
AMAZON_KEY=your-amazon-totp-secret

# The account name shown in Vendor Central's account selector after login.
# Must match exactly — check the picker after logging in manually.
VENDOR_ACCOUNT_NAME=Your Vendor Account Name

# ──────────────────────────────────────────────
# NetSuite credentials
# ──────────────────────────────────────────────
LONG_EMAIL=your-netsuite-email@example.com
NETSUITE_PASSWORD=your-netsuite-password
NETSUITE_KEY=your-netsuite-totp-secret

# NetSuite 2FA field IDs — defaults work for most instances.
# Update if your NetSuite login uses different element IDs.
NETSUITE_2FA_INPUT_ID=uif60_input
NETSUITE_2FA_SUBMIT_ID=uif76

# ──────────────────────────────────────────────
# File paths (Windows-style, update to your machine)
# ──────────────────────────────────────────────
DOWNLOAD_DIR=C:/Users/yourname/Downloads
LOG_DIR=C:/path/to/your/logs
SALES_DATA_DIR=C:/path/to/your/sales/data

# ──────────────────────────────────────────────
# Email
# ──────────────────────────────────────────────
REPORT_EMAIL_TO=recipient@your-company.com
